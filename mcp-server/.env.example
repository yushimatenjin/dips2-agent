# DIPS-REG DRS API credentials (issued by 国交省 航空局)
# Apply at: https://www.dips-reg.mlit.go.jp/contents/drs/manual.html
DIPS_CLIENT_ID=your-client-id-here
DIPS_CLIENT_SECRET=your-client-secret-here

# Environment: "production" or "development" (検証環境)
DIPS_ENV=development

# Local OAuth callback (must match the redirect_uri registered in your application)
DIPS_REDIRECT_URI=http://localhost:8765/callback
DIPS_CALLBACK_PORT=8765
